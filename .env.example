# ===========================================
# Required Infrastructure Variables
# ===========================================
# These are required server-only variables.
# Clients can only access NEXT_PUBLIC_* variables.

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5434
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DATABASE=gotly_dev

# Redis
REDIS_HOST=localhost
REDIS_PORT=6382
REDIS_DB=0
REDIS_USERNAME=
REDIS_PASSWORD=

# Better Auth
BETTER_AUTH_SECRET=replace-with-at-least-32-characters
BETTER_AUTH_URL=http://localhost:3000

# ===========================================
# Drizzle Migrations
# ===========================================
# Generate migrations after schema changes:
#   pnpm db:generate
#
# Apply migrations to database:
#   pnpm db:migrate
#
# Open Drizzle Studio (browser-based database explorer):
#   pnpm db:studio
